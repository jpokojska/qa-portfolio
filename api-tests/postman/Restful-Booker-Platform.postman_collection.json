				{
					"name": "POST Create Booking",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response time is less than 300ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(300);",
									"});",
									"",
									"pm.test(\"Response is JSON\", function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"// Zapis booking_id do zmiennej",
									"const response = pm.response.json();",
									"pm.environment.set(\"booking_id\", response.bookingid);",
									"",
									"pm.test(\"Booking is created with correct data\", function () {",
									"    pm.expect(response.booking.firstname).to.eql(\"Jan\");",
									"    pm.expect(response.booking.lastname).to.eql(\"Kowalski\");",
									"    pm.expect(response.booking.bookingdates.checkin).to.eql(\"2026-05-01\");",
									"    pm.expect(response.booking.bookingdates.checkout).to.eql(\"2026-05-03\");",
									"});",
									"",
									""
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Cookie",
								"value": "token={{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"roomid\": 1,\n    \"firstname\": \"Jan\",\n    \"lastname\": \"Kowalski\",\n    \"depositpaid\": false,\n    \"bookingdates\": {\n        \"checkin\": \"2026-05-01\",\n        \"checkout\": \"2026-05-03\"\n    }\n}",
							"options": {
